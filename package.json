{
  "private": true,
  "name": "remix-cloudflare-pages",
  "description": "An opinionated template for running Remix on Cloudflare Pages.",
  "license": "MIT",
  "scripts": {
    "prepare": "husky install",
    "build": "yarn run build:css && cross-env NODE_ENV=production remix build",
    "build:css": "tailwindcss -m -i ./styles/app.css -o app/styles/app.css",
    "dev": "cross-env NODE_ENV=development run-p dev:*",
    "postinstall": "remix setup cloudflare",
    "dev:remix": "remix watch",
    "dev:wrangler": "wrangler pages dev --local ./public --kv sessionStorage --binding $(cat .env)",
    "dev:css": "tailwindcss -w -i ./styles/app.css -o app/styles/app.css",
    "start": "yarn run dev:wrangler"
  },
  "dependencies": {
    "@remix-run/cloudflare-pages": "^1.3.4",
    "@remix-run/react": "^1.3.4",
    "react": "^17",
    "react-dom": "^17",
    "remix": "^1.3.4",
    "remix-auth": "^3.2.1",
    "remix-auth-socials": "^1.0.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^3.5.0",
    "@commitlint/cli": "^16.1.0",
    "@commitlint/config-conventional": "^16.0.0",
    "@remix-run/dev": "^1.3.4",
    "@remix-run/eslint-config": "^1.3.4",
    "@types/react": "^17.0.43",
    "@types/react-dom": "^17.0.9",
    "autoprefixer": "^10.4.4",
    "cross-env": "^7.0.3",
    "esbuild": "0.14.31",
    "eslint": "^8.12.0",
    "eslint-config-prettier": "^8.3.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.12",
    "prettier": "^2.6.2",
    "tailwindcss": "^3.0.23",
    "typescript": "^4.6.3",
    "wrangler": "0.0.24"
  },
  "engines": {
    "node": ">=16.7"
  },
  "sideEffects": false,
  "main": "dist/worker.js"
}
